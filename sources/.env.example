# sources/.env.example - copy the relevant vars into the repo-root .env (gitignored).
# NEVER commit real values. The refresh token rotates; the token store keeps the
# latest one, so QBO_REFRESH_TOKEN is only the bootstrap value from first consent.

# Which source the engine and MCP read.
SOURCE=synthetic                 # synthetic (default) | quickbooks

# --- QuickBooks Online (only needed when SOURCE=quickbooks) ---
QBO_ENV=sandbox                  # sandbox | production
QBO_CLIENT_ID=                   # from your Intuit developer app
QBO_CLIENT_SECRET=               # from your Intuit developer app
QBO_REFRESH_TOKEN=               # bootstrap refresh token from the first consent
QBO_REALM_ID=                    # the sandbox company (realm) id
QBO_REDIRECT_URI=http://localhost:8000/callback
QBO_ENTITY_ID=US                 # canonical entity id for the single sandbox company
QBO_ENTITY_NAME=QuickBooks Sandbox Co.
# QBO_TOKEN_STORE defaults to ~/.ai-finance/qbo_tokens.json (outside the repo).

# --- Engine override (set by sources/canonical/materialize.py; usually automatic) ---
# FINANCE_DATA_DIR=/abs/path/to/sources/canonical/_active
# FINANCE_LATEST_PERIOD=2026-05
